<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SecureScanner</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;background:#0f0f1a;color:#fff;min-height:100vh;padding:2rem 1rem}
.hero{max-width:680px;margin:0 auto;text-align:center}
.logo{display:inline-flex;align-items:center;gap:8px;margin-bottom:1.5rem}
.logo-icon{width:36px;height:36px;background:#1a1a2e;border-radius:8px;display:flex;align-items:center;justify-content:center}
.logo-icon i{color:#7f77dd;font-size:20px}
.logo-name{font-size:18px;font-weight:500}
.tagline{font-size:14px;color:#888;margin-bottom:2rem}
.tabs{display:flex;gap:4px;justify-content:center;margin-bottom:1.5rem}
.tab{padding:8px 20px;border-radius:20px;font-size:13px;border:1px solid #333;cursor:pointer;color:#888;background:transparent;transition:.15s}
.tab.active{background:#534AB7;color:#fff;border-color:#534AB7}
.drop-zone{border:1.5px dashed #333;border-radius:12px;padding:2.5rem;text-align:center;cursor:pointer;transition:.2s;background:#1a1a2e}
.drop-zone:hover{border-color:#7f77dd}
.drop-zone i{font-size:32px;color:#555;margin-bottom:12px;display:block}
.drop-zone p{font-size:14px;color:#888}
.drop-zone span{color:#7f77dd;font-weight:500}
.url-row{display:flex;gap:8px;margin-top:1rem}
.url-row input{flex:1;padding:10px 14px;border:1px solid #333;border-radius:8px;font-size:14px;background:#1a1a2e;color:#fff}
.url-row input::placeholder{color:#555}
.url-row button{padding:10px 20px;background:#534AB7;color:#fff;border:none;border-radius:8px;font-size:14px;cursor:pointer;font-weight:500}
.panel{display:none}
.panel.active{display:block}
.result-card{background:#1a1a2e;border:1px solid #2a2a3e;border-radius:12px;overflow:hidden;margin-top:1.5rem;text-align:left}
.result-header{padding:1rem 1.25rem;border-bottom:1px solid #2a2a3e;display:flex;align-items:center;gap:12px}
.threat-badge{display:flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:8px;flex-shrink:0}
.threat-badge.clean{background:#1a3a2a;color:#5cb85c}
.threat-badge.danger{background:#3a1a1a;color:#e05555}
.threat-badge.warning{background:#3a2e1a;color:#e0a040}
.threat-badge i{font-size:24px}
.result-meta h3{font-size:15px;font-weight:500}
.result-meta p{font-size:12px;color:#888;margin-top:2px}
.verdict-pill{margin-left:auto;padding:4px 14px;border-radius:20px;font-size:12px;font-weight:500}
.verdict-pill.clean{background:#1a3a2a;color:#5cb85c}
.verdict-pill.danger{background:#3a1a1a;color:#e05555}
.verdict-pill.warning{background:#3a2e1a;color:#e0a040}
.engines-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1px;background:#2a2a3e}
.engine-row{padding:10px 1.25rem;display:flex;align-items:center;gap:10px;background:#1a1a2e;font-size:13px}
.engine-name{flex:1;color:#ccc}
.engine-status{font-size:12px;font-weight:500;display:flex;align-items:center;gap:4px}
.engine-status.clean{color:#5cb85c}
.engine-status.detect{color:#e05555}
.engine-status.warn{color:#e0a040}
.engine-status i{font-size:14px}
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#2a2a3e}
.stat{background:#151525;padding:.75rem 1.25rem;text-align:center}
.stat-num{font-size:22px;font-weight:500}
.stat-num.red{color:#e05555}
.stat-num.green{color:#5cb85c}
.stat-label{font-size:11px;color:#888;margin-top:2px}
.detail-section{padding:1rem 1.25rem;border-top:1px solid #2a2a3e}
.detail-section h4{font-size:12px;font-weight:500;color:#888;text-transform:uppercase;letter-spacing:.04em;margin-bottom:10px}
.detail-row{display:flex;justify-content:space-between;font-size:13px;padding:4px 0;border-bottom:1px solid #2a2a3e}
.detail-row:last-child{border:none}
.detail-key{color:#888}
.detail-val{color:#ccc;font-family:monospace;font-size:12px}
.scan-btn{width:100%;margin-top:1rem;padding:12px;background:#534AB7;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:500;cursor:pointer}
.progress-wrap{margin-top:1.5rem;display:none}
.progress-label{font-size:13px;color:#888;margin-bottom:8px;display:flex;justify-content:space-between}
.progress-bar{height:4px;background:#2a2a3e;border-radius:2px;overflow:hidden}
.progress-fill{height:100%;background:#534AB7;border-radius:2px;width:0;transition:width .3s}
.file-chip{display:inline-flex;align-items:center;gap:8px;padding:6px 12px;background:#2a2a3e;border-radius:20px;font-size:13px;margin-top:.75rem}
</style>
</head>
<body>
<div class="hero">
  <div class="logo">
    <div class="logo-icon"><i class="ti ti-shield-check"></i></div>
    <span class="logo-name">SecureScanner</span>
  </div>
  <p class="tagline">Analyze suspicious files and URLs across 70+ security engines</p>
  <div class="tabs">
    <button class="tab active" onclick="switchTab('file',this)"><i class="ti ti-file" style="font-size:14px;vertical-align:-1px;margin-right:4px"></i>File</button>
    <button class="tab" onclick="switchTab('url',this)"><i class="ti ti-link" style="font-size:14px;vertical-align:-1px;margin-right:4px"></i>URL</button>
    <button class="tab" onclick="switchTab('hash',this)"><i class="ti ti-hash" style="font-size:14px;vertical-align:-1px;margin-right:4px"></i>Hash</button>
  </div>
  <div id="panel-file" class="panel active">
    <div class="drop-zone" onclick="triggerFile()" ondragover="event.preventDefault()" ondrop="handleDrop(event)">
      <i class="ti ti-cloud-upload"></i>
      <p>Drop a file here or <span>browse to upload</span></p>
      <p style="font-size:12px;margin-top:6px;color:#555">Max 650 MB · Any file type accepted</p>
    </div>
    <input type="file" id="fileInput" style="display:none" onchange="fileSelected(this)">
    <div id="fileChip" style="display:none">
      <span class="file-chip"><i class="ti ti-file"></i><span id="fileName">file.exe</span></span>
    </div>
    <button class="scan-btn" onclick="runScan('file')"><i class="ti ti-radar" style="font-size:16px;vertical-align:-2px;margin-right:6px"></i>Scan file</button>
  </div>
  <div id="panel-url" class="panel">
    <div class="url-row">
      <input type="text" id="urlInput" placeholder="https://example.com or paste a suspicious URL">
      <button onclick="runScan('url')">Scan</button>
    </div>
  </div>
  <div id="panel-hash" class="panel">
    <div class="url-row">
      <input type="text" id="hashInput" placeholder="MD5, SHA-1, or SHA-256 hash">
      <button onclick="runScan('hash')">Lookup</button>
    </div>
  </div>
  <div class="progress-wrap" id="progressWrap">
    <div class="progress-label"><span id="progressText">Submitting to engines…</span><span id="progressPct">0%</span></div>
    <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
  </div>
</div>
<div id="resultArea" style="max-width:680px;margin:0 auto"></div>
<script>
let activeTab='file';
function switchTab(tab,btn){
  activeTab=tab;
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('active'));
  document.getElementById('panel-'+tab).classList.add('active');
  btn.classList.add('active');
  document.getElementById('resultArea').innerHTML='';
}
function triggerFile(){document.getElementById('fileInput').click()}
function fileSelected(inp){
  if(!inp.files.length)return;
  document.getElementById('fileName').textContent=inp.files[0].name;
  document.getElementById('fileChip').style.display='block';
}
function handleDrop(e){
  e.preventDefault();
  const f=e.dataTransfer.files[0];
  if(!f)return;
  document.getElementById('fileName').textContent=f.name;
  document.getElementById('fileChip').style.display='block';
}
function runScan(type){
  const pw=document.getElementById('progressWrap');
  const fill=document.getElementById('progressFill');
  const ptext=document.getElementById('progressText');
  const ppct=document.getElementById('progressPct');
  document.getElementById('resultArea').innerHTML='';
  pw.style.display='block';
  let pct=0;
  const steps=['Submitting to engines…','Running heuristics…','Checking signatures…','Aggregating results…'];
  const iv=setInterval(()=>{
    pct=Math.min(pct+Math.random()*18,99);
    fill.style.width=pct+'%';
    ppct.textContent=Math.round(pct)+'%';
    ptext.textContent=steps[Math.floor(pct/25)%steps.length];
    if(pct>=99){clearInterval(iv);showResult(type);}
  },200);
}
function showResult(type){
  document.getElementById('progressWrap').style.display='none';
  const scenarios=[
    {verdict:'danger',label:'Malicious',icon:'ti-virus',detects:5,clean:67,engines:[
      {name:'Kaspersky',st:'detect',icon:'ti-alert-circle',label:'Trojan.GenericKD'},
      {name:'Bitdefender',st:'detect',icon:'ti-alert-circle',label:'Gen:Variant.Zusy'},
      {name:'ESET',st:'detect',icon:'ti-alert-circle',label:'Win32/Spy.Banker'},
      {name:'Malwarebytes',st:'detect',icon:'ti-alert-circle',label:'Trojan.Downloader'},
      {name:'McAfee',st:'detect',icon:'ti-alert-circle',label:'RDN/Generic.dx'},
      {name:'Windows Defender',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Avast',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Sophos',st:'warn',icon:'ti-alert-triangle',label:'Suspicious'},
    ]},
    {verdict:'clean',label:'Clean',icon:'ti-shield-check',detects:0,clean:72,engines:[
      {name:'Kaspersky',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Bitdefender',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'ESET',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Malwarebytes',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'McAfee',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Windows Defender',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Avast',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Sophos',st:'clean',icon:'ti-circle-check',label:'No threats'},
    ]},
    {verdict:'warning',label:'Suspicious',icon:'ti-alert-triangle',detects:2,clean:70,engines:[
      {name:'Kaspersky',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Bitdefender',st:'warn',icon:'ti-alert-triangle',label:'Heuristic match'},
      {name:'ESET',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Malwarebytes',st:'warn',icon:'ti-alert-triangle',label:'PUP.Optional'},
      {name:'McAfee',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Windows Defender',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Avast',st:'clean',icon:'ti-circle-check',label:'No threats'},
      {name:'Sophos',st:'clean',icon:'ti-circle-check',label:'No threats'},
    ]},
  ];
  const s=scenarios[Math.floor(Math.random()*scenarios.length)];
  const total=s.detects+s.clean;
  const meta=type==='file'
    ?{name:document.getElementById('fileName')?.textContent||'uploaded_file.exe',sub:'SHA-256: a1b2c3d4e5f6...7890abcdef · 2.4 MB · PE32 executable'}
    :type==='url'
    ?{name:document.getElementById('urlInput')?.value||'https://example.com',sub:'IP: 93.184.216.34 · Last seen: just now'}
    :{name:document.getElementById('hashInput')?.value||'a1b2c3d4...7890abcdef',sub:'First seen: 2024-03-12 · Type: PE32'};
  document.getElementById('resultArea').innerHTML=`
  <div class="result-card">
    <div class="result-header">
      <div class="threat-badge ${s.verdict}"><i class="ti ${s.icon}"></i></div>
      <div class="result-meta"><h3>${meta.name}</h3><p>${meta.sub}</p></div>
      <span class="verdict-pill ${s.verdict}">${s.label}</span>
    </div>
    <div class="stats-row">
      <div class="stat"><div class="stat-num ${s.detects>0?'red':'green'}">${s.detects}</div><div class="stat-label">detections</div></div>
      <div class="stat"><div class="stat-num green">${s.clean}</div><div class="stat-label">clean</div></div>
      <div class="stat"><div class="stat-num">${total}</div><div class="stat-label">engines</div></div>
    </div>
    <div class="detail-section">
      <h4>File details</h4>
      <div class="detail-row"><span class="detail-key">MD5</span><span class="detail-val">d41d8cd98f00b204e9800998ecf8427e</span></div>
      <div class="detail-row"><span class="detail-key">SHA-1</span><span class="detail-val">da39a3ee5e6b4b0d3255bfef95601890afd80709</span></div>
      <div class="detail-row"><span class="detail-key">SHA-256</span><span class="detail-val">a1b2c3d4e5f6...7890abcdef</span></div>
      <div class="detail-row"><span class="detail-key">File type</span><span class="detail-val">PE32 Windows executable</span></div>
      <div class="detail-row"><span class="detail-key">First seen</span><span class="detail-val">2025-11-04 08:31 UTC</span></div>
    </div>
    <div class="detail-section">
      <h4>Engine results</h4>
      <div class="engines-grid">
        ${s.engines.map(e=>`<div class="engine-row"><span class="engine-name">${e.name}</span><span class="engine-status ${e.st}"><i class="ti ${e.icon}"></i>${e.label}</span></div>`).join('')}
      </div>
    </div>
  </div>`;
}
</script>
</body>
</html>
